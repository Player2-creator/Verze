      "EXPO_PUBLIC_APPWRITE_PROJECT_NAME": "Verze",
      "EXPO_PUBLIC_APPWRITE_ENDPOINT": "https://nyc.cloud.appwrite.io/v1",
      "EXPO_PUBLIC_APPWRITE_DATABASE_ID": "6a1dc5d60039b7b270d6",
      "EXPO_PUBLIC_APPWRITE_COLLECTION_ID": "users",
      "EXPO_PUBLIC_APPWRITE_BUCKET_ID": "6a1dc682002e38da2322",
      "router": {},
      "eas": {
        "projectId": "85f48206-e54f-43a0-b890-34beae4aa79f"
      }
    }
  }
}
